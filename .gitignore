from vl53l5cx_ctypes import VL53L5CX
import numpy as np, time

tof = VL53L5CX()
tof.start_ranging()
for _ in range(5):
    while not tof.data_ready():
        time.sleep(0.01)
    data = tof.get_data()
    grid = np.array(data.distance_mm, dtype=np.int32).reshape(8, 8)
    print(grid)
    print()
    time.sleep(0.5)
tof.stop_ranging()
EOF
